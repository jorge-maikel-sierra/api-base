# Servidor
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Base de datos
DATABASE_URL=postgresql://user:password@localhost:5432/app_dev
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/app_test

# Autenticación
JWT_SECRET=tu_secret_muy_seguro_cambia_esto
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=tu_refresh_secret_muy_seguro_cambia_esto
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=otro_secret_muy_seguro_cambia_esto

# CORS
ALLOWED_ORIGINS=http://localhost:3000
