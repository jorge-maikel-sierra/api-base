# Entorno de pruebas
NODE_ENV=test
PORT=3001
LOG_LEVEL=silent

# Base de datos de prueba (separada de la de desarrollo)
DATABASE_URL=postgresql://jorgesierra@localhost:5432/app_test
TEST_DATABASE_URL=postgresql://jorgesierra@localhost:5432/app_test
DB_POOL_SIZE=3
DB_POOL_TIMEOUT=10

# Autenticación
JWT_SECRET=secret_para_tests_no_usar_en_produccion
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=refresh_secret_para_tests_no_usar_en_produccion
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=session_secret_para_tests

# CORS
ALLOWED_ORIGINS=http://localhost:3001
